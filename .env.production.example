# =============================================================================
# POS SaaS — Production Environment Template
# Copy to .env and fill in every value marked CHANGE_ME before deploying.
# Never commit .env to version control.
# =============================================================================

# ============================================================
# APPLICATION
# ============================================================
APP_NAME="POS System"
APP_ENV=production
APP_KEY=                        # Run: php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.{DOMAIN}
APP_VERSION=1.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Next.js frontend origin — used for CORS, email links, payment callbacks
FRONTEND_URL=https://app.{DOMAIN}

# ============================================================
# LOGGING
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning               # debug|info|notice|warning|error|critical

# ============================================================
# DATABASE — Central (Laravel + Tenancy central tables)
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_system
DB_USERNAME=posapp              # CHANGE_ME — matches MySQL user created during setup
DB_PASSWORD=CHANGE_ME           # CHANGE_ME — strong password
DB_SOCKET=                      # Leave empty unless using Unix socket

# Tenant database prefix (stancl/tenancy creates: {prefix}{store_uuid})
TENANCY_DATABASE_PREFIX=pos_store_
TENANCY_DATABASE_SUFFIX=

# ============================================================
# SESSION / CACHE / QUEUE
# ============================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.{DOMAIN}        # Leading dot = share session across subdomains

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_PREFIX=pos_

# ============================================================
# REDIS
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_ME        # Set in redis.conf: requirepass CHANGE_ME
REDIS_PORT=6379

# ============================================================
# SANCTUM (API authentication)
# ============================================================
SANCTUM_STATEFUL_DOMAINS=app.{DOMAIN},admin.{DOMAIN}
SANCTUM_TOKEN_PREFIX=

# JWT token lifetimes (minutes)
JWT_TTL=10080                   # 7 days
JWT_REFRESH_TTL=20160           # 14 days

# ============================================================
# MAIL (transactional — system emails: verify, reset, billing)
# ============================================================
# Switch to resend once RESEND_API_KEY is configured
MAIL_MAILER=resend
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=CHANGE_ME         # Same as RESEND_API_KEY — see Resend dashboard
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@{DOMAIN}"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# COMMUNICATIONS PROVIDERS
# Resend (Email — receipts, campaigns)
# ============================================================
RESEND_API_KEY=CHANGE_ME        # https://resend.com — free tier: 3K/month
RESEND_WEBHOOK_SECRET=CHANGE_ME # From Resend webhook dashboard — prevents spoofing

# ============================================================
# COMMUNICATIONS PROVIDERS
# Twilio (SMS + WhatsApp)
# ============================================================
TWILIO_ACCOUNT_SID=CHANGE_ME    # https://console.twilio.com
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1XXXXXXXXXX # Purchased Twilio phone number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio Sandbox or approved number
TWILIO_TEST_NUMBER=             # Optional: override recipient in test mode

# ============================================================
# FILE STORAGE (AWS S3 or compatible)
# ============================================================
FILESYSTEM_DISK=s3              # Switch from local to s3 for production uploads
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=CHANGE_ME            # e.g. pos-system-uploads
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_ENDPOINT=                 # Set only for S3-compatible (MinIO, DigitalOcean Spaces, etc.)

# ============================================================
# BACKUP (scripts/backup/backup.sh)
# ============================================================
MYSQL_USER=posapp               # DB user with SELECT, LOCK TABLES privileges
MYSQL_PASS=CHANGE_ME            # Same as DB_PASSWORD above
MYSQL_HOST=127.0.0.1
CENTRAL_DB=pos_system
TENANT_DB_PREFIX=pos_store_

BACKUP_S3_BUCKET=CHANGE_ME      # Separate bucket from uploads, e.g. pos-system-backups
BACKUP_S3_ENDPOINT=             # Leave empty for AWS S3; set for Wasabi / DO Spaces
BACKUP_S3_KEY=CHANGE_ME         # IAM key with s3:PutObject, s3:ListBucket, s3:DeleteObject
BACKUP_S3_SECRET=CHANGE_ME
BACKUP_RETENTION_DAYS=30
BACKUP_NOTIFY_EMAIL=            # Optional: ops email for backup failure alerts

# ============================================================
# PAYMENT GATEWAYS
# ============================================================

# Stripe
STRIPE_KEY=pk_live_CHANGE_ME    # Publishable key
STRIPE_SECRET=sk_live_CHANGE_ME # Secret key
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME  # From Stripe webhook dashboard

# PayPal
PAYPAL_MODE=live                # sandbox | live
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME

# JazzCash (Pakistan)
JAZZCASH_MERCHANT_ID=CHANGE_ME
JAZZCASH_PASSWORD=CHANGE_ME
JAZZCASH_INTEGRITY_SALT=CHANGE_ME
JAZZCASH_MODE=production        # sandbox | production
JAZZCASH_RETURN_URL="${FRONTEND_URL}/payment/jazzcash/callback"

# Easypaisa (Pakistan)
EASYPAISA_STORE_ID=CHANGE_ME
EASYPAISA_HASH_KEY=CHANGE_ME
EASYPAISA_MODE=production       # sandbox | production
EASYPAISA_RETURN_URL="${FRONTEND_URL}/payment/easypaisa/callback"

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# Free trial duration (days) — shown on registration page
FREE_TRIAL_DAYS=14

# API rate limits (requests per minute per IP)
RATE_LIMIT_AUTH=10              # Login / register endpoints
RATE_LIMIT_API=120              # General authenticated API calls

# ============================================================
# API LOGGING
# ============================================================
API_LOGGING_ENABLED=true
API_LOG_RETENTION_DAYS=30       # Auto-pruned by Laravel scheduler
API_LOG_MAX_BODY_SIZE=10000     # Max request/response body bytes to store

# ============================================================
# MONITORING & OBSERVABILITY
# ============================================================

# Sentry error tracking (https://sentry.io — free tier: 5K errors/month)
SENTRY_LARAVEL_DSN=             # Leave empty to disable; format: https://KEY@sentry.io/PROJECT_ID
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions; increase to 1.0 if debugging performance

# Health check — protects GET /api/v1/health/detail from public access
# Generate: openssl rand -hex 32
HEALTH_CHECK_TOKEN=CHANGE_ME

# ============================================================
# VITE (kept for package compatibility — not used in API-only mode)
# ============================================================
VITE_APP_NAME="${APP_NAME}"
