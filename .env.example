APP_NAME="POS System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Karachi
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Frontend URL (Next.js)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_system
DB_USERNAME=root
DB_PASSWORD=

# Session / Cache / Queue
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# Redis (recommended for production)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@possystem.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (for production storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite (not used for API-only but kept for compatibility)
VITE_APP_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# JWT / API Tokens
JWT_TTL=10080
JWT_REFRESH_TTL=20160

# ============================================
# PAYMENT GATEWAYS
# ============================================

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# JazzCash (Pakistan)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_MODE=sandbox
JAZZCASH_RETURN_URL="${FRONTEND_URL}/payment/jazzcash/callback"

# Easypaisa (Pakistan)
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_MODE=sandbox
EASYPAISA_RETURN_URL="${FRONTEND_URL}/payment/easypaisa/callback"

# ============================================
# APPLICATION SETTINGS
# ============================================

# Free trial duration in days
FREE_TRIAL_DAYS=14

# API rate limits (per minute)
RATE_LIMIT_AUTH=10
RATE_LIMIT_API=120

# API Logging
API_LOGGING_ENABLED=true
API_LOG_RETENTION_DAYS=30
API_LOG_MAX_BODY_SIZE=10000
